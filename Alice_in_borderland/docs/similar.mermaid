    end

    subgraph Compute["Computation"]
        H[Cosine Similarity<br/>Target vs All]
        I[Sort by Score<br/>Descending]
        J[Exclude Self Match]
    end

    subgraph Output["Output"]
        K[Top 5 Similar Books<br/>List of Titles]
    end

    A --> B
    A --> C
