flowchart TD
    subgraph Input["Input"]
        A[Book ID]
    end

    subgraph Data["Data Loading"]
        B[Download Target Book]
        C[Download 21 Reference Books]
        D[Load from Cache if exists]
    end

    subgraph Process["Processing"]
        E[Text Cleaning]
        F[TF-IDF Vectorization<br/>max_features=1000]
